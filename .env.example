  # Server configuration
  PORT=3000

  # Monday.com configuration
  MONDAY_API_KEY=your_monday_api_token_here
  MONDAY_BOARD_ID=__REPLACE_WITH_BOARD_ID__
  MONDAY_STATUS_COLUMN_ID=Status
  MONDAY_STATUS_VALUE=Completed
  MONDAY_STORE_COLUMN_ID=numeric_mm10p284

  # Google Sheets configuration
  GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@project.iam.gserviceaccount.com
  GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_key_or_path_to_json_file
  GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
  GOOGLE_SHEET_NAME=Sheet1

  # Google Sheets column mapping (A-Z, case insensitive)
  GOOGLE_SHEET_TIMESTAMP_COLUMN=A
  GOOGLE_SHEET_STOREID_COLUMN=B
  GOOGLE_SHEET_STORENAME_COLUMN=L
  GOOGLE_SHEET_ACCOUNTSTATE_COLUMN=N
  GOOGLE_SHEET_STOREOWNER_COLUMN=E
  GOOGLE_SHEET_ADSADDRESS_COLUMN=F
  GOOGLE_SHEET_MAILBOXCOLOR_COLUMN=G
  GOOGLE_SHEET_MANAGER_COLUMN=H
  GOOGLE_SHEET_TIMESAVINGKIOSK_COLUMN=I
  GOOGLE_SHEET_PRODUCTSNOTOFFERED_COLUMN=J
  GOOGLE_SHEET_GENERALFOCUS_COLUMN=K
